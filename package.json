{
  "name": "hl7-bridge-mcp",
  "version": "0.1.0",
  "description": "MCP server to parse, map and validate clinical messages between HL7 v2.x and FHIR R4/R6, with human-readable error explanations",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Glenn Tomassi",
  "homepage": "https://github.com/GlennRTC/hl7-bridge-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlennRTC/hl7-bridge-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/GlennRTC/hl7-bridge-mcp/issues"
  },
  "keywords": [
    "mcp",
    "hl7",
    "hl7v2",
    "fhir",
    "healthcare",
    "interoperability",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "hl7-bridge-mcp": "dist/server/index.js"
  },
  "files": [
    "dist",
    "maps",
    "SECURITY.md",
    "README.md",
    "USAGE.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/server/index.js",
    "start:http": "node dist/server/http.js",
    "dev": "tsx src/server/index.ts",
    "dev:http": "tsx src/server/http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fhirpath": "^5.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fhir": "^0.0.44",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
